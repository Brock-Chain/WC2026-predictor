# Data (downloadable / regenerable — not version controlled)
data/raw/
data/processed/

# Fitted model artifacts (large NetCDF traces). The *shipped* trace is committed
# (~35 MB) so the hosting CI can re-render without an expensive MCMC refit;
# other/experimental traces stay ignored.
models/*.nc
models/*.netcdf
!models/trace.nc

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Backtest run logs (the results .json/.txt are kept; raw run logs are noise)
reports/*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/
